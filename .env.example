REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
GITHUB_WEBHOOK_SECRET=changeme
GIT_WORKSPACE_ROOT=app/workspace
GROQ_API_KEY=changeme
GROQ_MODEL=llama-3.3-70b-versatile
# GitHub App auth (replaces the old PAT). GITHUB_APP_PRIVATE_KEY_B64 is the
# App's downloaded .pem, base64-encoded as a single line, e.g.:
#   base64 -w0 your-app-private-key.pem
GITHUB_APP_ID=changeme
GITHUB_APP_PRIVATE_KEY_B64=changeme

# Used only by evaluation/judge_results.py (the optional LLM-as-judge eval
# pass) -- not read by the app itself, so it's fine to leave unset unless
# you're running that script.
GEMINI_API_KEY=changeme
GEMINI_MODEL=gemini-3.5-flash

# LangSmith tracing. On by default (LANGSMITH_TRACING defaults to true in
# code) but only actually activates once LANGSMITH_API_KEY is a real key
# (from smith.langchain.com) -- leave it as "changeme" to run untraced.
# Shows every specialist's ReAct tool-call loop and the Synthesizer call as
# a full trace per PR review.
LANGSMITH_API_KEY=changeme
LANGSMITH_PROJECT=pr-review-agent
# LANGSMITH_TRACING=false  # uncomment to force tracing off even with a key set
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # only needed for EU/self-hosted
