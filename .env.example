REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
GITHUB_WEBHOOK_SECRET=changeme
GIT_WORKSPACE_ROOT=app/workspace
GROQ_API_KEY=changeme
GROQ_MODEL=llama-3.3-70b-versatile
# GitHub App auth (replaces the old PAT). GITHUB_APP_PRIVATE_KEY_B64 is the
# App's downloaded .pem, base64-encoded as a single line, e.g.:
#   base64 -w0 your-app-private-key.pem
GITHUB_APP_ID=changeme
GITHUB_APP_PRIVATE_KEY_B64=changeme

# Used only by evaluation/judge_results.py (the optional LLM-as-judge eval
# pass) -- not read by the app itself, so it's fine to leave unset unless
# you're running that script.
GEMINI_API_KEY=changeme
GEMINI_MODEL=gemini-3.5-flash
